{
  "name": "va-horizon-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run css:build && node scripts/build-site.mjs",
    "fonts:extract": "node scripts/extract-fonts.mjs",
    "internal-links": "node scripts/generate-internal-links.mjs",
    "seo:harden": "node scripts/seo-hardening.mjs",
    "seo:audit": "node scripts/audit-seo.mjs",
    "lint:html": "htmlhint \"_site/**/*.html\"",
    "lint:css": "stylelint \"VAHorizonWebsiteStyle/**/*.css\" \"css/**/*.css\" \"cards.css\"",
    "lint:js": "eslint \"**/*.js\"",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "check": "npm run build && npm run lint && npm run images:check && npm run links",
    "links": "linkinator _site --recurse --skip \"https://.*\" --skip \"mailto:.*\" --skip \"terms$\" --skip \"privacy$\" --skip \"client-agreement$\" --json > link-report.json",
    "img:build": "node scripts/image-pipeline.mjs",
    "images:check": "node scripts/check-images.mjs",
    "css:build": "tailwindcss -i ./css/tw-input.css -o ./css/tailwind.min.css --minify"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "htmlhint": "^1.1.4",
    "linkinator": "^7.6.1",
    "sharp": "^0.33.5",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "tailwindcss": "^3.4.19"
  }
}
